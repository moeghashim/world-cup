{
  "rewrites": [
    {
      "source": "/ingest/static/:path*",
      "destination": "https://us-assets.i.posthog.com/static/:path*"
    },
    {
      "source": "/ingest/:path*",
      "destination": "https://us.i.posthog.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-fixtures",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/poll-results",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/score",
      "schedule": "*/15 * * * *"
    }
  ]
}
